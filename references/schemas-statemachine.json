{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SPECULA State Machine Schema",
  "description": "Formal specification for state machines implementing SPECULA governance",
  "type": "object",
  "required": ["id", "initial_state", "states"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique state machine identifier",
      "pattern": "^[a-z0-9_-]+_sm$"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string"
    },
    "initial_state": {
      "type": "string",
      "description": "ID of the initial state"
    },
    "states": {
      "type": "object",
      "description": "Map of state_id -> state definition",
      "additionalProperties": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["normal", "terminal", "error", "escalation"],
            "description": "normal=intermediate, terminal=success end state, error=failure state, escalation=human review"
          },
          "description": {
            "type": "string"
          },
          "entry_actions": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Actions executed when entering state"
          },
          "exit_guards": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {"type": "string"},
                "condition": {"type": "string"},
                "on_fail": {"type": "string"},
                "severity": {
                  "type": "string",
                  "enum": ["block", "warn", "log"]
                }
              }
            },
            "description": "Guards that must pass to exit state"
          },
          "allowed_transitions": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Which states can be transitioned to from here"
          },
          "timeout": {
            "type": "object",
            "properties": {
              "duration_ms": {"type": "number"},
              "on_timeout": {"type": "string"}
            },
            "description": "Optional timeout and fallback action"
          }
        }
      }
    },
    "transitions": {
      "type": "array",
      "description": "Explicit transition definitions",
      "items": {
        "type": "object",
        "required": ["id", "from_state", "to_state"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^transition_[a-z0-9_]+$"
          },
          "from_state": {
            "type": "string"
          },
          "to_state": {
            "type": "string"
          },
          "trigger": {
            "type": "string",
            "description": "What triggers this transition"
          },
          "preconditions": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Conditions that must be true"
          },
          "actions": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Actions to execute during transition"
          },
          "guard_ids": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Guard checks that must pass"
          },
          "is_fallback": {
            "type": "boolean",
            "description": "Is this a fallback/error recovery transition?"
          }
        }
      }
    },
    "guards": {
      "type": "array",
      "description": "Constitutional guard conditions",
      "items": {
        "type": "object",
        "required": ["id", "condition"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^guard_[a-z0-9_]+$"
          },
          "name": {"type": "string"},
          "applies_to": {
            "type": "string",
            "enum": ["state", "transition", "output"],
            "description": "Where this guard applies"
          },
          "applies_at_state": {
            "type": "string",
            "description": "Which state this applies to (if applicable)"
          },
          "condition": {
            "type": "string",
            "description": "Guard condition (natural language or formal)"
          },
          "principle": {
            "type": "string",
            "description": "Which constitutional principle this enforces"
          },
          "action_on_violation": {
            "type": "string",
            "enum": ["block", "escalate", "log", "retry"],
            "description": "What happens if violated"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "error_message": {
            "type": "string"
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "description": "Reusable action definitions",
      "items": {
        "type": "object",
        "required": ["id", "implementation"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {"type": "string"},
          "implementation": {
            "type": "string",
            "description": "How to execute this action"
          },
          "parameters": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "error_handling": {
      "type": "object",
      "description": "System-wide error handling",
      "properties": {
        "default_error_state": {
          "type": "string"
        },
        "uncaught_exception_action": {
          "type": "string"
        },
        "critical_failure_action": {
          "type": "string"
        }
      }
    },
    "constraints": {
      "type": "array",
      "description": "Global state machine constraints",
      "items": {
        "type": "object",
        "properties": {
          "constraint": {"type": "string"},
          "applies_globally": {"type": "boolean"}
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "author": {"type": "string"},
        "created_timestamp": {"type": "string"},
        "last_modified": {"type": "string"},
        "framework_version": {"type": "string"},
        "references": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
